# ============================================================
# Glory Simon Interiors - Site Visit Booking System
# Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in your values
# cp .env.example .env
# ============================================================

# ─── Server ─────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MySQL Database ─────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=glory_simon_booking
DB_CONNECTION_LIMIT=10
DB_QUEUE_LIMIT=0

# ─── JWT Authentication ──────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=24h

# ─── Email (Nodemailer / SMTP) ───────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_specific_password
EMAIL_FROM=Glory Simon Interiors <noreply@glorysimoninteriors.com>

# ─── Firebase Admin SDK ─────────────────────────────────────
# Path to your Firebase service account JSON key file
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# OR provide individual fields:
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com

# ─── WhatsApp (Template-Based) ───────────────────────────────
# For production: connect to Twilio/Gupshup/WATI
# For development: messages stored in notifications table
WHATSAPP_ENABLED=false
WHATSAPP_PROVIDER=twilio
WHATSAPP_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WHATSAPP_AUTH_TOKEN=your_twilio_auth_token
WHATSAPP_FROM=whatsapp:+14155238886

# ─── File Uploads ────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,webp

# ─── CORS ────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Logging ─────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=./logs

# ─── PDF Export ──────────────────────────────────────────────
PDF_COMPANY_NAME=Glory Simon Interiors
PDF_COMPANY_ADDRESS=Chennai, Tamil Nadu, India
PDF_COMPANY_PHONE=+91-XXXXXXXXXX
PDF_COMPANY_EMAIL=info@glorysimoninteriors.com
PDF_LOGO_PATH=./assets/logo.png
